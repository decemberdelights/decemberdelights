# =============================================================================
# December Delights — Environment Variables
# =============================================================================
# Frontend (Vercel): set NEXT_PUBLIC_* vars
# Backend (Railway): set all vars except NEXT_PUBLIC_*
# =============================================================================

# --- Backend URL (used by Next.js rewrites on Vercel) ---
BACKEND_URL=https://your-app.up.railway.app

# --- Backend Auth ---
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ADMIN_DEFAULT_PASSWORD=changeme
ADMIN_USERNAME=admin

# --- CORS (comma-separated origins allowed on backend) ---
CORS_ORIGINS=http://localhost:3000,https://your-domain.vercel.app

# --- Environment ---
ENV=development
HOST=0.0.0.0
PORT=10000

# --- Supabase (client-side, prefixed with NEXT_PUBLIC_) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server-side only, backend uses these) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Email (Brevo SMTP) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login-email@example.com
SMTP_PASSWORD=your-brevo-smtp-key
SENDER_EMAIL=your-sending-email@example.com
SENDER_NAME=December Delights

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
