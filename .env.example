# Backend API URL (Railway deployment) - used server-side by proxy route
BACKEND_URL=https://december-delights-production-32ca.up.railway.app

# Local development
FASTAPI_URL=http://localhost:4000

# Backend auth
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ADMIN_DEFAULT_PASSWORD=changeme
ADMIN_USERNAME=admin

# CORS (set on Railway backend)
CORS_ORIGINS=http://localhost:3000,https://decemberdelights.vercel.app

# Environment
ENV=development
HOST=0.0.0.0
PORT=10000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
