# =============================================================================
# December Delights — Environment Variables
# =============================================================================
# Frontend (Render): set NEXT_PUBLIC_* vars + BACKEND_URL
# Backend (Render): set all vars except NEXT_PUBLIC_*
# =============================================================================

# --- Backend URL (used by Next.js rewrites on Render) ---
BACKEND_URL=https://your-api.onrender.com

# --- Direct Backend URL (used by franchise form to bypass Next.js proxy) ---
NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# --- Backend Auth ---
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ADMIN_DEFAULT_PASSWORD=changeme
ADMIN_USERNAME=admin

# --- CORS (comma-separated origins allowed on backend) ---
CORS_ORIGINS=http://localhost:3000,https://www.your-domain.com,https://your-domain.com,https://your-frontend.onrender.com

# --- Frontend URL (used in email templates for links) ---
FRONTEND_URL=https://www.your-domain.com

# --- Environment ---
ENV=development
HOST=0.0.0.0
PORT=10000

# --- Supabase (client-side, prefixed with NEXT_PUBLIC_) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server-side only, backend uses these) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Email (Brevo SMTP) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login-email@example.com
SMTP_PASSWORD=your-brevo-smtp-key
SENDER_EMAIL=your-sending-email@example.com
SENDER_NAME=December Delights

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
